[
  {
    "// NOTE": "Add these service definitions to your portal's services.json"
  },
  {
    "id": "adressen",
    "name": "Addresses",
    "typ": "WMS",
    "url": "https://your-geoserver.example.com/geoserver/wms",
    "layers": "your_workspace:address_layer",
    "format": "image/png",
    "version": "1.1.1",
    "transparent": true,
    "gfiAttributes": "showAll",
    "gfiTheme": "default",
    "gfiFormat": "text/xml",
    "featureCount": 1,
    "layerAttribution": "Your Attribution",
    "legendURL": "",
    "datasets": []
  },
  {
    "id": "wahlraeume",
    "name": "Wahlräume",
    "typ": "GeoJSON",
    "url": "https://geoportal.muenchen.de/wahlraumfinder/ressources/data/wahlraeume.json",
    "gfiAttributes": {
      "wahllokal_name": "Name",
      "stranam": "Straße",
      "plz": "PLZ",
      "ort": "Ort",
      "wbz": "Wahlbezirk",
      "stbz": "Stadtbezirk"
    },
    "gfiTheme": "default",
    "layerAttribution": "KVR München",
    "legendURL": "",
    "datasets": []
  },
  {
    "id": "wahlkreise",
    "name": "Wahlkreise",
    "typ": "GeoJSON",
    "url": "https://geoportal.muenchen.de/wahlraumfinder/ressources/data/wahlkreise.json",
    "gfiAttributes": {
      "bezeichnung": "Wahlkreis"
    },
    "gfiTheme": "default",
    "layerAttribution": "KVR München",
    "legendURL": "",
    "datasets": []
  },
  {
    "// NOTES": {
      "adressen": "WMS service with GetFeatureInfo (text/xml) support. Must expose the attribute specified in addressLayerPollingStationAttribute via GFI response.",
      "wahlraeume": "Replace url with your polling station data. Adjust gfiAttributes to match your data structure",
      "wahlkreise": "Optional layer for electoral districts. Adjust gfiAttributes as needed"
    }
  }
]
